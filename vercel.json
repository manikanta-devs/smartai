{
  "buildCommand": "npm run build --workspace=@resume-saas/frontend",
  "outputDirectory": "packages/frontend/dist",
  "framework": "vite",
  "regions": ["iad1"],
  "env": {
    "VITE_API_URL": "@vite_api_url",
    "VITE_GEMINI_API_KEY": "@vite_gemini_api_key"
  },
  "envPrefix": "VITE_",
  "installCommand": "npm install --workspaces"
}
