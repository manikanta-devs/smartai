NODE_ENV=development
PORT=5000

# Database Configuration
# For SQLite (development/testing):
DATABASE_URL="file:./dev.db"

# For PostgreSQL (production):
# First ensure PostgreSQL is running: 
#   Windows: net start postgresql-x64-14
#   macOS: brew services start postgresql@14
#   Linux: sudo systemctl start postgresql
# Then run: createdb resume_saas
DATABASE_URL="postgresql://postgres:your_password@localhost:5432/resume_saas?schema=public"

# JWT Secrets (use strong, random values in production)
JWT_SECRET="your-super-secret-jwt-key-minimum-32-characters-long"
JWT_ACCESS_SECRET="access-secret-minimum-32-characters-for-production"
JWT_REFRESH_SECRET="refresh-secret-minimum-32-characters-for-production"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Frontend & API URLs
FRONTEND_URL="http://localhost:5173"
CLIENT_ORIGIN="http://localhost:5173"
RESUME_AI_URL="http://localhost:8501"

# File Upload (Optional)
OPENAI_API_KEY="sk-your-openai-key-here"
MAX_FILE_SIZE=5242880
